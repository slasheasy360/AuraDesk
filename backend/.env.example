# Server
PORT=3001
NODE_ENV=development
JWT_SECRET=your-jwt-secret-here
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/auradesk?schema=public

# Token Encryption
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# Meta (Facebook, Instagram, WhatsApp)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
FACEBOOK_REDIRECT_URI=https://auradesk-k5en.onrender.com/auth/facebook/callback
META_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# WhatsApp
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_SYSTEM_USER_TOKEN=your-system-user-token

# Google / Gmail
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-ngrok-url.ngrok-free.app/auth/gmail/callback

# Gmail Pub/Sub (real-time notifications)
GMAIL_PUBSUB_TOPIC=projects/YOUR_PROJECT_ID/topics/gmail-push

# ngrok (for local dev webhooks)
# NGROK_URL=https://your-ngrok-url.ngrok-free.app
